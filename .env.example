# Planet Pulse — Environment Variables
# Copy this file to .env.local and fill in values.

# Required for NASA FIRMS fire detections (optional — app works without it)
# Get a key at: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=

# Site URL (used for Open Graph metadata and canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
